# ─── Postgres (shared by n8n and Convex) ──────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password   # openssl rand -hex 16

# ─── Convex self-hosted ────────────────────────────────────────────────────────
# Random 64-char hex — generate with: openssl rand -hex 32
CONVEX_INSTANCE_SECRET=replace_with_openssl_rand_hex_32

# Public URLs as seen from the browser (update host/domain for production)
CONVEX_CLOUD_ORIGIN=http://localhost:3210
CONVEX_SITE_ORIGIN=http://localhost:3211

# Generated during first-boot setup via setup.sh (do not set manually)
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ─── n8n ──────────────────────────────────────────────────────────────────────
# Generate once: openssl rand -base64 32
# WARNING: Never change after first run — all stored credentials will break
N8N_ENCRYPTION_KEY=replace_with_openssl_rand_base64_32

N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Europe/Paris

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Email (Azure Communication Services) ────────────────────────────────────
# Full endpoint URL, e.g. https://my-resource.communication.azure.com
AZURE_COMMUNICATION_ENDPOINT=https://your-resource.communication.azure.com
# Access key (base64) from ACS resource → Keys blade
AZURE_COMMUNICATION_ACCESS_KEY=your_base64_access_key
# Verified sender address on your ACS-linked email domain
AZURE_COMMUNICATION_FROM_ADDRESS=veille@yourdomain.com

# ─── Domains (VPS only — used by Caddy for automatic HTTPS) ───────────────────
# Point these DNS A records to your VPS IP before running setup.sh
APP_DOMAIN=app.yourdomain.com
CONVEX_DOMAIN=convex.yourdomain.com
CONVEX_SITE_DOMAIN=convex-site.yourdomain.com
N8N_DOMAIN=n8n.yourdomain.com
DASHBOARD_DOMAIN=dashboard.yourdomain.com
