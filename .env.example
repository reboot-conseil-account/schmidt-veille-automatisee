# ─── Postgres (n8n internal storage) ──────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password

# ─── n8n ──────────────────────────────────────────────────────────────────────
# Generate once: openssl rand -base64 32
# WARNING: Never change after first run — all stored credentials will break
N8N_ENCRYPTION_KEY=replace_with_openssl_rand_base64_32

N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Europe/Paris

# ─── Convex ───────────────────────────────────────────────────────────────────
# HTTP actions base URL — from Convex dashboard > Settings (ends in .convex.site)
CONVEX_URL=https://your-project-name.convex.site

# Shared secret between n8n and Convex HTTP actions
# Generate: openssl rand -hex 32
CONVEX_API_KEY=replace_with_openssl_rand_hex_32

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Email ────────────────────────────────────────────────────────────────────
# Configure Gmail OAuth2 directly in n8n UI, or use SMTP below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
