# Caddyfile — automatic HTTPS via Let's Encrypt.
# Set the domain variables in your .env file.
# Caddy will obtain and renew certificates automatically.

{$APP_DOMAIN} {
    reverse_proxy frontend:80
}

{$CONVEX_DOMAIN} {
    reverse_proxy convex-backend:3210
}

{$CONVEX_SITE_DOMAIN} {
    reverse_proxy convex-backend:3211
}

{$N8N_DOMAIN} {
    reverse_proxy n8n:5678
}

{$DASHBOARD_DOMAIN} {
    reverse_proxy convex-dashboard:6791
}
